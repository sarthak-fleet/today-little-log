# Cache the HTML envelope at the CF edge so repeat hits skip the origin.
# CF Pages was returning cf-cache-status: DYNAMIC with just s-maxage;
# adding max-age makes CF actually cache HTML at the edge.
/
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800
/*.html
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

# Vite emits hash-stable bundles under /assets/.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
