{
  "buildCommand": "node scripts/bundle-api.mjs && vite build",
  "functions": {
    "api/*.ts": {
      "regions": ["bom1"]
    }
  },
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth?authPath=$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
